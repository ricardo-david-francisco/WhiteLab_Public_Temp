# Pinned tool versions + SHA256 for the WhiteLab dev sandbox.
# Edit only via PR. The bootstrap script refuses to install if a hash mismatches.
#
# Each entry:
#   <TOOL>_VERSION  = upstream version tag
#   <TOOL>_SHA256   = sha256 of the downloaded asset (linux x86_64)
#
# Sources used to obtain hashes:
#   gh    -> https://github.com/cli/cli/releases/download/v${V}/gh_${V}_checksums.txt
#   age   -> direct sha256 of the release tarball (upstream does not publish a SHA256SUMS file)
#   sops  -> https://github.com/getsops/sops/releases/download/v${V}/sops-v${V}.checksums.txt

GH_VERSION=2.92.0
GH_SHA256=b57848131bdf0c229cd35e1f2a51aa718199858b2e728410b37e89a428943ec4

AGE_VERSION=1.2.1
AGE_SHA256=7df45a6cc87d4da11cc03a539a7470c15b1041ab2b396af088fe9990f7c79d50

SOPS_VERSION=3.9.4
SOPS_SHA256=5488e32bc471de7982ad895dd054bbab3ab91c417a118426134551e9626e4e85

# Python toolchain (used by tools/anonymize/ and tools/verify/).
# The system python3 is used; we only create a venv under .sandbox/venv.
PYTHON_BIN=python3
