---
# yamllint configuration for WhiteLab.
# Aligns local editor warnings with the CI yamllint step.
extends: default

rules:
  line-length: disable
  document-start: disable
  truthy:
    check-keys: false
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  # The VS Code YAML formatter pads flow sequences ([ master ]); accept both.
  brackets:
    min-spaces-inside: 0
    max-spaces-inside: 1
  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1
